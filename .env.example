# PostHog analytics + session replay (client-side; the public key is safe to ship).
# Get these from PostHog → Project Settings → Project API Key / Host.
# Copy this file to .env and fill in, and add the same vars in the
# Cloudflare Pages project (Settings → Environment variables) for production builds.
PUBLIC_POSTHOG_KEY=phc_your_project_key_here
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
