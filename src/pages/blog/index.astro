---
import Base from "../../layouts/Base.astro";
import Section from "../../components/Section.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order || +b.data.date - +a.data.date
);
---

<Base title="Blog" description="Field notes on developer community, agents, and building with Devin.">
  <Section eyebrow="Field notes" index="☕">
    <div class="mb-14 max-w-2xl">
      <h1 class="font-serif text-4xl sm:text-5xl">The Roastery</h1>
      <p class="mt-4 text-[var(--color-slate)]">
        Essays on developer community, agent orchestration, and what I'd build for Cognition.
        Editorial by design — highlight any line and you'll see Devin blue.
      </p>
    </div>

    <ul class="divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
      {
        posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="group flex flex-col gap-2 py-7 transition-colors hover:bg-[var(--color-foam)] sm:flex-row sm:items-baseline sm:gap-8">
              <div class="eyebrow shrink-0 sm:w-40">
                {post.data.category}
                <time class="block text-[var(--color-line-strong)]" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                </time>
              </div>
              <div>
                <h2 class="font-serif text-2xl leading-snug transition-colors group-hover:text-[var(--color-blue)]">
                  {post.data.title}
                </h2>
                <p class="mt-2 max-w-2xl text-[var(--color-slate)]">{post.data.description}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>
</Base>
