---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import WaxPaper from "../components/WaxPaper.astro";
import Globe from "../components/Globe.astro";
import EventList from "../components/EventList.astro";
import SocialProofWall from "../components/SocialProofWall.astro";
import { getEvents, COMMUNITY_STATS, SOCIAL_PROOF } from "../lib/events";

const events = await getEvents();

const WHAT_WE_DO = [
  {
    name: "Cafe Cognition",
    body: "Take over a cafe for the day. Build with local Devin users, grab coffee + credits, meet the community.",
    icon: "cafe",
  },
  {
    name: "Workshops",
    body: "Hands-on sessions with power users. Orchestration patterns, fleets of Devins, non-coding workflows.",
    icon: "workshop",
  },
  {
    name: "Meetups",
    body: "Casual evening gatherings in your city. Short talks, live demos, plenty of hallway time.",
    icon: "meetup",
  },
  {
    name: "Hackathons",
    body: "Weekend builds with the community. Ship real projects, win credits, meet collaborators.",
    icon: "hackathon",
  },
];

const PROGRAMS = [
  { name: "Ambassadors", body: "Lead the community in your city. Three tiers, real perks, a seat at the product table.", cta: "Apply", href: "#" },
  { name: "Devin Office Hours", body: "Weekly virtual drop-in. Get unblocked, share builds, feed the product loop.", cta: "Join", href: "#" },
  { name: "Discord", body: "Chat in real time. Help, tips, collaborators.", cta: "Join", href: "https://discord.gg/GjCYNGChrw" },
  { name: "Event Support", body: "Hosting something? Request swag, credits, and a run-of-show kit.", cta: "Request", href: "#" },
];

const ICON_MAP: Record<string, string> = {
  cafe: `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8"><path d="M5 12h18v2a8 8 0 0 1-8 8h-2a8 8 0 0 1-8-8v-2Z" stroke="currentColor" stroke-width="1.5"/><path d="M23 14h2a3 3 0 0 1 0 6h-2" stroke="currentColor" stroke-width="1.5"/><path d="M8 26h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 6v3M16 4v5M20 6v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/></svg>`,
  workshop: `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8"><rect x="4" y="8" width="24" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M12 14l3 2-3 2v-4Z" fill="currentColor"/><path d="M4 24l6 4M28 24l-6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/></svg>`,
  meetup: `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8"><circle cx="11" cy="11" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="21" cy="11" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M6 24c0-3.3 2.7-6 6-6h1M26 24c0-3.3-2.7-6-6-6h-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="16" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M10 28c0-3.9 2.7-6 6-6s6 2.1 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  hackathon: `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8"><path d="M16 4l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6l2-6Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><rect x="7" y="22" width="18" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M12 25h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/></svg>`,
};
---

<Base title="Community" description="A warmer, more centralized home for the Devin community — events, ambassadors, and programs.">
  {/* HERO */}
  <Section eyebrow="A redesign of devin.ai/community" index="☕">
    <div class="max-w-3xl">
      <h1 class="font-serif text-5xl leading-[1.04] sm:text-6xl">
        Join the global Devin community.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[var(--color-ink-soft)]">
        Cafe Cognition pop-ups, workshops, hackathons, and meetups around the world —
        warm, human, and centralized. (Today's <a href="https://devin.ai/community" class="link-blue">community page</a> is five links and a Google Form. We can do better.)
      </p>
    </div>

    {/* stats */}
    <div class="mt-12 grid grid-cols-2 gap-px overflow-hidden rounded-md border border-[var(--color-line)] bg-[var(--color-line)] sm:grid-cols-4">
      {COMMUNITY_STATS.map((s) => (
        <div class="bg-[var(--color-foam)] p-6">
          <div class="font-mono text-3xl text-[var(--color-blue)]">{s.value}</div>
          <div class="mt-1 text-sm text-[var(--color-slate)]">{s.label}</div>
        </div>
      ))}
    </div>
  </Section>

  {/* WHAT WE DO — cards with SVG imagery */}
  <Section index="01" eyebrow="What we do">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {WHAT_WE_DO.map((w) => (
        <WaxPaper class="p-6">
          <div class="mb-4 text-[var(--color-blue)]" set:html={ICON_MAP[w.icon]} />
          <h3 class="font-serif text-xl">{w.name}</h3>
          <p class="mt-2 text-sm text-[var(--color-slate)]">{w.body}</p>
        </WaxPaper>
      ))}
    </div>
  </Section>

  {/* EVENTS — interactive globe + filterable list */}
  <Section index="02" eyebrow="Upcoming · powered by Luma (mock data)" tone="roast">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.1fr]">
      <Globe events={events} class="max-w-md mx-auto lg:mx-0" />
      <EventList events={events} />
    </div>
  </Section>

  {/* SOCIAL PROOF WALL */}
  <Section index="03" eyebrow="From the community">
    <h2 class="mb-8 max-w-xl text-3xl sm:text-4xl">
      Builders shipping together.
    </h2>
    <SocialProofWall proofs={SOCIAL_PROOF} />
  </Section>

  {/* PROGRAMS */}
  <Section index="04" eyebrow="Programs">
    <div class="grid gap-5 sm:grid-cols-2">
      {PROGRAMS.map((p) => (
        <WaxPaper class="flex items-start justify-between gap-4 p-6">
          <div>
            <h3 class="font-serif text-xl">{p.name}</h3>
            <p class="mt-2 max-w-md text-sm text-[var(--color-slate)]">{p.body}</p>
          </div>
          <a href={p.href} class="shrink-0 rounded-full bg-[var(--color-blue)] px-4 py-2 text-sm font-medium text-white">
            {p.cta}
          </a>
        </WaxPaper>
      ))}
    </div>
  </Section>
</Base>
