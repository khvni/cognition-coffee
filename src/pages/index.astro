---
import Base from "../layouts/Base.astro";
import BootTerminal from "../components/BootTerminal.astro";
import Desktop from "../components/Desktop.astro";
import { BIO } from "../data/experience";
---

<Base bare>
  <h1 class="sr-only">Cognition Coffee Co. &mdash; {BIO.hook}</h1>
  <div class="vm-boot" data-vm-boot>
    <div class="vm-stage">
      <BootTerminal class="vm-terminal" />
    </div>
  </div>
  <div class="vm-desktop" data-vm-desktop hidden>
    <Desktop />
  </div>
</Base>

<script>
  import { readSession } from "../lib/os";

  const boot = document.querySelector<HTMLElement>("[data-vm-boot]");
  const desk = document.querySelector<HTMLElement>("[data-vm-desktop]");

  const show = (loggedIn: boolean) => {
    if (!boot || !desk) return;
    boot.hidden = loggedIn;
    desk.hidden = !loggedIn;
  };

  show(readSession().loggedIn);
  document.addEventListener("ccvm:login", () => show(true));
  document.addEventListener("ccvm:logout", () => show(false));
</script>

<style>
  .vm-stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4vw, 3rem);
    background:
      radial-gradient(120% 90% at 50% 0%, color-mix(in srgb, var(--color-blue) 9%, var(--os-desktop-bg)) 0%, var(--os-desktop-bg) 60%),
      var(--os-desktop-bg);
  }
  .vm-terminal {
    width: min(720px, 100%);
  }
</style>
