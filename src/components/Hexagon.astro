---
/**
 * Cognition-style hexagon mark, remixed with a coffee bean at its core.
 * Nods to Cognition's hexagonal logo geometry while signalling "coffee".
 * Props: size (px), class for color (uses currentColor).
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <!-- outer hexagon -->
  <path
    d="M16 2.3 27.9 9v14L16 29.7 4.1 23V9L16 2.3Z"
    fill="currentColor"
    fill-opacity="0.08"
    stroke="currentColor"
    stroke-width="1.4"
  />
  <!-- coffee bean -->
  <ellipse cx="16" cy="16" rx="5.2" ry="7.4" fill="currentColor" />
  <path
    d="M16 9.2c-2.6 2 -2.6 11.6 0 13.6"
    stroke="var(--color-paper, #edeceb)"
    stroke-width="1.3"
    fill="none"
    stroke-linecap="round"
  />
</svg>
