---
/**
 * About app body — the candidate's DevRel thesis and track record, drawn from
 * src/data/experience.ts (BIO, PROOF_POINTS, PILLARS, EXPERIENCE) so it mirrors
 * the canonical /about page from one source. Header carries the full-page link.
 */
import { BIO, PROOF_POINTS, PILLARS, EXPERIENCE } from "../../data/experience";
---

<div class="app app-about">
  <header class="about-head">
    <h3 class="about-name">{BIO.name}</h3>
    <p class="about-where">{BIO.location}</p>
    <p class="about-thesis">{BIO.thesis}</p>
  </header>

  <ul class="about-stats">
    {
      PROOF_POINTS.map((p) => (
        <li>
          <b>{p.value}</b>
          <span>{p.label}</span>
        </li>
      ))
    }
  </ul>

  <div class="about-pillars">
    {
      PILLARS.map((p) => (
        <div class="about-pillar">
          <span class="eyebrow">{p.verb}</span>
          <h4>{p.title}</h4>
          <p>{p.body}</p>
        </div>
      ))
    }
  </div>

  <ol class="about-xp">
    {
      EXPERIENCE.map((x) => (
        <li>
          <div class="xp-top">
            <span class="xp-org">{x.org}</span>
            <span class="xp-when">{x.when}</span>
          </div>
          <span class="xp-role">{x.role}</span>
          <p class="xp-detail">{x.detail}</p>
        </li>
      ))
    }
  </ol>
</div>

<style>
  .app {
    padding: 1.4rem 1.5rem 2rem;
    font-family: var(--font-sans);
  }
  .about-name {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }
  .about-where {
    margin: 0.1rem 0 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .about-thesis {
    margin: 0 0 1.4rem;
    max-width: 50ch;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--color-slate);
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.6rem;
    margin: 0 0 1.6rem;
    padding: 0;
    list-style: none;
  }
  .about-stats li {
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    background: var(--color-card);
  }
  .about-stats b {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-blue);
  }
  .about-stats span {
    font-size: 0.74rem;
    line-height: 1.3;
    color: var(--color-slate);
  }

  .about-pillars {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }
  .about-pillar h4 {
    margin: 0.25rem 0 0.3rem;
    font-family: var(--font-serif);
    font-size: 1.08rem;
  }
  .about-pillar p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-slate);
  }

  .about-xp {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--color-line);
    padding-top: 1.2rem;
  }
  .xp-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .xp-org {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .xp-when {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    white-space: nowrap;
  }
  .xp-role {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-blue);
  }
  .xp-detail {
    margin: 0.3rem 0 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-slate);
  }
</style>
