---
/**
 * Numbered section wrapper — mirrors Cognition's "01 / 02 / 03" rhythm.
 * Props:
 *   index   -> "01"
 *   eyebrow -> small mono label
 *   id      -> anchor id
 *   tone    -> "paper" (default) | "roast" (dark espresso section)
 */
interface Props {
  index?: string;
  eyebrow?: string;
  id?: string;
  tone?: "paper" | "roast";
  class?: string;
}
const { index, eyebrow, id, tone = "paper", class: className = "" } = Astro.props;
const toneClass = tone === "roast" ? "roast" : "";
---

<section id={id} class={`relative ${toneClass} ${className}`}>
  <div class="mx-auto w-full max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
    {(index || eyebrow) && (
      <div class="mb-10 flex items-baseline gap-4 border-b border-[var(--color-line)] pb-4">
        {index && <span class="font-mono text-sm text-[var(--color-slate)]">{index}</span>}
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      </div>
    )}
    <slot />
  </div>
</section>
