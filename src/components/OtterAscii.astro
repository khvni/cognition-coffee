---
/**
 * The Devin otter, rendered in VT100 ASCII — a nod to the Devin CLI launch
 * terminal (devin@terminal:~$) and the otter mascot (plushies, Slackbot, merch).
 * Here the otter holds a coffee cup instead of a laptop: the brand handshake
 * between "autonomous software engineer" and "artisan coffee company".
 *
 * NOTE (cloud-devin): this ASCII is a solid v1 placeholder. Feel free to
 * replace with a higher-fidelity otter (keep it monospace + single color).
 */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;

const otter = String.raw`        .-"""-.
       /  .-.  \
      |  /   \  |      .---.
      |  \   /  |     (  ~  )   <- fresh pour
       \  '-'  /       '---'
    .--' .---. '--.    //
   /    ( o o )    \  //
  |      \ ^ /      ||/
  |   .-'''''''-.   ||
   \ (  cognition ) /
    '-'._______.'-'
        |     |
        '-----'`;
---

<pre
  class={`font-mono text-[0.62rem] sm:text-xs leading-[1.15] whitespace-pre select-none ${className}`}
  aria-label="ASCII art of the Devin otter holding a coffee"
>{otter}</pre>
