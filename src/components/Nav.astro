---
import { NAV, CTA, SITE } from "../lib/site";
import Hexagon from "./Hexagon.astro";
---

<header class="sticky top-0 z-50 border-b border-[var(--color-line)] bg-[color-mix(in_srgb,var(--color-paper)_82%,transparent)] backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
    <!-- Logo lockup -->
    <a href="/" class="group flex items-center gap-2.5" aria-label={`${SITE.shortName} home`}>
      <Hexagon size={26} class="text-[var(--color-ink)] transition-colors group-hover:text-[var(--color-blue)]" />
      <span class="font-serif text-[1.05rem] leading-none tracking-tight">
        Cognition <span class="text-[var(--color-bean)]">Coffee&nbsp;Co.</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-8 md:flex">
      {
        NAV.map((item) =>
          item.children ? (
            <div class="group relative">
              <button class="flex items-center gap-1 py-2 text-sm text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-ink)]">
                {item.label}
                <svg width="10" height="10" viewBox="0 0 10 10" class="transition-transform group-hover:rotate-180" aria-hidden="true">
                  <path d="M2 3.5 5 6.5 8 3.5" stroke="currentColor" stroke-width="1.3" fill="none" />
                </svg>
              </button>
              {/* Hover dropdown */}
              <div class="invisible absolute right-0 top-full w-64 translate-y-1 pt-2 opacity-0 transition-all duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                <div class="wax grain overflow-hidden p-1.5">
                  {item.children.map((child) => (
                    <a href={child.href} class="relative z-10 block rounded-[4px] px-3 py-2.5 transition-colors hover:bg-[var(--color-blue-soft)]">
                      <span class="block text-sm font-medium">{child.label}</span>
                      {child.note && <span class="block text-xs text-[var(--color-slate)]">{child.note}</span>}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="py-2 text-sm text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-ink)]">
              {item.label}
            </a>
          )
        )
      }
      <a href={CTA.href} class="rounded-full bg-[var(--color-blue)] px-4 py-2 text-sm font-medium text-white transition-transform hover:-translate-y-0.5">
        {CTA.emoji} {CTA.label}
      </a>
    </div>

    <!-- Mobile toggle -->
    <button id="nav-toggle" class="md:hidden" aria-label="Open menu" aria-expanded="false">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden border-t border-[var(--color-line)] px-5 py-4 md:hidden">
    {
      NAV.flatMap((item) =>
        item.children
          ? [
              <p class="eyebrow pt-3">{item.label}</p>,
              ...item.children.map((c) => (
                <a href={c.href} class="block py-2 text-[var(--color-ink-soft)]">{c.label}</a>
              )),
            ]
          : [<a href={item.href} class="block py-2 text-[var(--color-ink-soft)]">{item.label}</a>]
      )
    }
    <a href={CTA.href} class="mt-3 inline-block rounded-full bg-[var(--color-blue)] px-4 py-2 text-sm font-medium text-white">{CTA.emoji} {CTA.label}</a>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-mobile");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!open));
  });
</script>
