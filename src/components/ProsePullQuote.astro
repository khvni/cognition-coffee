---
/**
 * Editorial pull-quote — a standout block for key sentences.
 * Devin-blue left border, serif italic, slightly inset on cream.
 */
interface Props {
  cite?: string;
}
const { cite } = Astro.props;
---

<figure class="prose-pullquote my-10 border-l-[3px] border-[var(--color-blue)] pl-6 sm:pl-8">
  <blockquote class="font-serif text-[1.35rem] leading-[1.55] tracking-tight text-[var(--color-ink)] italic sm:text-[1.5rem]">
    <slot />
  </blockquote>
  {cite && (
    <figcaption class="mt-3 font-mono text-xs tracking-wide text-[var(--color-slate)] uppercase">
      &mdash; {cite}
    </figcaption>
  )}
</figure>
