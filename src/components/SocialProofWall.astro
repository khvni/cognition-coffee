---
/**
 * Social-proof wall — Cursor-style scrolling testimonial grid.
 * Renders community voices in a staggered masonry layout.
 */
import type { SocialProof } from "../lib/events";

interface Props {
  proofs: SocialProof[];
  class?: string;
}
const { proofs, class: className = "" } = Astro.props;
---

<div class={`proof-wall grid gap-4 sm:grid-cols-2 lg:grid-cols-3 ${className}`}>
  {proofs.map((p) => (
    <div class="proof-card wax grain relative overflow-hidden p-5">
      <div class="relative z-10">
        <blockquote class="text-sm leading-relaxed text-[var(--color-ink-soft)]">
          &ldquo;{p.quote}&rdquo;
        </blockquote>
        <div class="mt-4 flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-blue)] font-mono text-xs text-white">
            {p.name.charAt(0)}
          </div>
          <div>
            <p class="text-sm font-medium text-[var(--color-ink)]">{p.name}</p>
            <p class="font-mono text-xs text-[var(--color-slate)]">{p.handle} &middot; {p.city}</p>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .proof-card {
    transition: transform 0.25s var(--ease-out-soft);
  }
  .proof-card:hover {
    transform: translateY(-2px);
  }
</style>
