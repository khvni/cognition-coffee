---
/**
 * Filterable event grid — renders MOCK_EVENTS as hairline cards with a
 * client-side type filter. Data flows from src/lib/events.ts; the template
 * never hardcodes events. Reskinned to the industrial-editorial tokens
 * (light paper, mono labels, Devin-blue accent).
 */
import type { CommunityEvent } from "../lib/events";

interface Props {
  events: CommunityEvent[];
  class?: string;
}
const { events, class: className = "" } = Astro.props;

const fmt = (d: string) =>
  new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric" });

const kinds = [...new Set(events.map((e) => e.kind))];
---

<div class={`event-list-wrap ${className}`}>
  <div class="mb-6 flex flex-wrap gap-2" role="toolbar" aria-label="Filter events by type">
    <button class="event-filter-btn active font-mono text-xs" data-kind="all">all</button>
    {kinds.map((k) => (
      <button class="event-filter-btn font-mono text-xs" data-kind={k}>{k.replace("-", " ")}</button>
    ))}
  </div>

  <ul class="event-list grid gap-4 sm:grid-cols-2">
    {events.map((e) => (
      <li class="event-item" data-kind={e.kind}>
        <article class="flex h-full items-start gap-4 border border-[var(--color-line)] bg-[var(--color-card)] p-5 transition-colors hover:border-[var(--color-line-strong)]">
          <div class="shrink-0 border border-[var(--color-line)] px-2.5 py-1.5 text-center font-mono">
            <span class="block text-xs uppercase text-[var(--color-slate)]">{fmt(e.date).split(" ")[0]}</span>
            <span class="block text-lg leading-none text-[var(--color-ink)]">{fmt(e.date).split(" ")[1]}</span>
          </div>
          <div class="min-w-0">
            <h3 class="font-serif text-lg leading-snug">{e.title}</h3>
            <p class="mt-1 font-mono text-xs text-[var(--color-slate)]">
              {e.city}, {e.country}
            </p>
            <div class="mt-3 flex items-center gap-3">
              <span class="eyebrow border border-[var(--color-line)] px-2 py-0.5 text-[0.62rem]">{e.kind.replace("-", " ")}</span>
              <a href={e.rsvpUrl} class="font-mono text-xs text-[var(--color-blue)] transition-opacity hover:opacity-70">
                RSVP &rarr;
              </a>
            </div>
          </div>
        </article>
      </li>
    ))}
  </ul>
</div>

<script>
  function initFilter(wrap: HTMLElement) {
    const buttons = wrap.querySelectorAll<HTMLButtonElement>(".event-filter-btn");
    const items = wrap.querySelectorAll<HTMLLIElement>(".event-item");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const kind = btn.dataset.kind;
        buttons.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        items.forEach((item) => {
          const show = kind === "all" || item.dataset.kind === kind;
          item.style.display = show ? "" : "none";
        });
      });
    });
  }

  document.querySelectorAll<HTMLElement>(".event-list-wrap").forEach(initFilter);
</script>

<style>
  .event-filter-btn {
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-line-strong);
    color: var(--color-slate);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    text-transform: capitalize;
  }
  .event-filter-btn:hover {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }
  .event-filter-btn.active {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: #fff;
  }
</style>
